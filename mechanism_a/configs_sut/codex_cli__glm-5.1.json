{
  "sut_id": "codex_cli_glm51",
  "agent_name": "codex_cli",
  "image": "emnlp/codex-cli:latest",
  "base_model": "glm-5.1",
  "container_env": {
    "OE_CODEX_PROVIDER": "closeai",
    "OE_CODEX_BASE_URL": "https://api.openai-proxy.org/v1",
    "OE_CODEX_KEY_VAR": "OE_CLOSEAI_KEY",
    "OE_CLOSEAI_KEY": "{host_env:CLOSEAI_API_KEY}",
    "OE_MODEL": "glm-5.1",
    "OE_RUN_TIMEOUT": "360"
  },
  "docker_run_extra_args": ["--network=host", "--cpus=2", "--memory=4g"]
}
